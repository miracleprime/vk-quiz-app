<!doctype html>
<html lang="ru">
<head>
  <meta charset="UTF-8">
  <title>Результаты квиза</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.7/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
  <nav class="navbar navbar-expand-lg bg-body-tertiary border-bottom">
    <div class="container">
      <a class="navbar-brand" href="/dashboard">VK Quiz App</a>
      <div>
        <span class="me-3"><%= user.username %></span>
        <a href="/logout" class="btn btn-outline-secondary btn-sm">Выйти</a>
      </div>
    </div>
  </nav>

  <main class="container py-4">
    <div class="mb-4">
      <h1>Результаты квиза</h1>
      <p class="text-muted mb-1">
        Квиз: <strong><%= room.title %></strong>
      </p>
      <p class="text-muted mb-1">
        Категория: <%= room.category || 'Без категории' %>
      </p>
      <p class="text-muted mb-1">
        Код комнаты: <strong><%= room.code %></strong>
      </p>
      <p class="text-muted">
        Статус:
        <% if (room.status === 'finished') { %>
          <span class="badge text-bg-success">Завершён</span>
        <% } else if (room.status === 'active') { %>
          <span class="badge text-bg-warning">Идёт</span>
        <% } else { %>
          <span class="badge text-bg-secondary">Ожидание</span>
        <% } %>
      </p>

      <a href="/dashboard" class="btn btn-outline-secondary">Назад в кабинет</a>
      <a href="/rooms/<%= room.id %>/host" class="btn btn-outline-primary">Открыть комнату</a>
    </div>

    <% if (leaderboard.length === 0) { %>
      <div class="alert alert-info">
        В этой комнате пока нет участников.
      </div>
    <% } else { %>
      <div class="card">
        <div class="card-body">
          <h2 class="h4 mb-3">Итоговый лидерборд</h2>

          <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
              <thead>
                <tr>
                  <th>Место</th>
                  <th>Участник</th>
                  <th>Баллы</th>
                  <th>Ответов</th>
                  <th>Подключился</th>
                </tr>
              </thead>
              <tbody>
                <% leaderboard.forEach(function(participant, index) { %>
                  <tr>
                    <td>
                      <% if (index === 0) { %>
                        🥇
                      <% } else if (index === 1) { %>
                        🥈
                      <% } else if (index === 2) { %>
                        🥉
                      <% } else { %>
                        <%= index + 1 %>
                      <% } %>
                    </td>
                    <td><strong><%= participant.name %></strong></td>
                    <td><%= participant.score %></td>
                    <td><%= participant.answer_count %></td>
                    <td><%= participant.joined_at %></td>
                  </tr>
                <% }) %>
              </tbody>
            </table>
          </div>
        </div>
      </div>
    <% } %>
  </main>
</body>
</html>