<!doctype html>
<html lang="ru">
<head>
  <meta charset="UTF-8">
  <title>Комната участника</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.7/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
  <main class="container py-5">
    <div class="card mx-auto player-card">
      <div class="card-body">
        <div class="text-center mb-4">
          <h1 class="h3 mb-3"><%= room.title %></h1>

          <p class="lead">
            Вы подключились как <strong><%= participant.name %></strong>
          </p>

          <p class="text-muted mb-0">
            Код комнаты: <strong><%= room.code %></strong>
          </p>
        </div>

        <div id="questionArea">
          <div class="alert alert-info">
            Ожидайте запуска вопроса организатором.
          </div>
        </div>

        <div id="answerResult" class="mt-3"></div>

        <div id="leaderboardArea" class="mt-4"></div>
      </div>
    </div>
  </main>

  <script>
    window.ROOM_ID = Number('<%= room.id %>');
    window.PARTICIPANT_ID = Number('<%= participant.id %>');
  </script>
  <script src="/socket.io/socket.io.js"></script>
  <script src="/js/player.js"></script>
</body>
</html>