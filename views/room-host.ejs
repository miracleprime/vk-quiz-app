<!doctype html>
<html lang="ru">
<head>
  <meta charset="UTF-8">
  <title>Комната организатора</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.7/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
  <nav class="navbar navbar-expand-lg bg-body-tertiary border-bottom">
    <div class="container">
      <a class="navbar-brand" href="/dashboard">VK Quiz App</a>
      <div>
        <span class="me-3"><%= user.username %></span>
        <a href="/logout" class="btn btn-outline-secondary btn-sm">Выйти</a>
      </div>
    </div>
  </nav>

  <main class="container py-4">
    <div class="row g-4">
      <div class="col-lg-5">
        <div class="card mb-3">
          <div class="card-body">
            <h1 class="h3"><%= room.title %></h1>
            <p class="text-muted mb-2">
              Категория: <%= room.category || 'Без категории' %>
            </p>

            <div class="room-code-box my-4">
              <div class="text-muted">Код комнаты</div>
              <div class="room-code"><%= room.code %></div>
            </div>

            <p>
              Участники открывают страницу <strong>/join</strong> и вводят этот код.
            </p>

            <button id="nextQuestionBtn" class="btn btn-success">Показать следующий вопрос</button>
            <button id="finishQuizBtn" class="btn btn-danger">Завершить квиз</button>
            <a href="/dashboard" class="btn btn-outline-secondary">В кабинет</a>
          </div>
        </div>

        <div class="card">
          <div class="card-body">
            <h2 class="h4">Текущий вопрос</h2>
            <div id="currentQuestionHost" class="text-muted">
              Вопрос ещё не запущен.
            </div>
          </div>
        </div>
      </div>

      <div class="col-lg-7">
        <div class="card">
          <div class="card-body">
            <h2 class="h4 mb-3">Участники и баллы</h2>

            <div id="participantsList">
              <% if (participants.length === 0) { %>
                <div class="alert alert-info mb-0">
                  Пока никто не подключился.
                </div>
              <% } else { %>
                <ul class="list-group">
                  <% participants.forEach(function(participant) { %>
                    <li class="list-group-item d-flex justify-content-between">
                      <span><%= participant.name %></span>
                      <span><%= participant.score %> баллов</span>
                    </li>
                  <% }) %>
                </ul>
              <% } %>
            </div>

            <div id="leaderboardHost" class="mt-4"></div>
          </div>
        </div>
      </div>
    </div>
  </main>

  <script>
    window.ROOM_ID = Number('<%= room.id %>');
  </script>
  <script src="/socket.io/socket.io.js"></script>
  <script src="/js/host.js"></script>
</body>
</html>