<!doctype html>
<html lang="ru">
<head>
  <meta charset="UTF-8">
  <title>Подключиться к квизу</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.7/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
  <main class="container py-5">
    <div class="auth-card mx-auto">
      <h1 class="mb-4">Подключиться к квизу</h1>

      <% if (error) { %>
        <div class="alert alert-danger"><%= error %></div>
      <% } %>

      <form method="post" action="/join">
        <div class="mb-3">
          <label class="form-label">Ваше имя</label>
          <input class="form-control" name="name" placeholder="Например: Иван" required>
        </div>

        <div class="mb-3">
          <label class="form-label">Код комнаты</label>
          <input class="form-control text-uppercase" name="code" placeholder="Например: A7K2Q" required>
        </div>

        <button class="btn btn-primary w-100" type="submit">Войти в квиз</button>
      </form>

      <p class="mt-3">
        <a href="/">На главную</a>
      </p>
    </div>
  </main>
</body>
</html>